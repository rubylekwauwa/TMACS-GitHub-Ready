{
  "routes": [
    {
      "route": "/cas-login",
      "rewrite": "/api/cas-login"
    },
    {
      "route": "/cas-callback",
      "rewrite": "/api/cas-callback"
    },
    {
      "route": "/cas-logout",
      "rewrite": "/api/cas-logout"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".mp3": "audio/mpeg",
    ".png": "image/png"
  }
}
